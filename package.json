{
  "private": true,
  "devDependencies": {
    "semantic-release": "^24",
    "@semantic-release/commit-analyzer": "^13",
    "@semantic-release/release-notes-generator": "^14",
    "@semantic-release/github": "^11",
    "@semantic-release/exec": "^7"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "docker build -t ghcr.io/${GITHUB_REPOSITORY}:${nextRelease.version} -t ghcr.io/${GITHUB_REPOSITORY}:latest .",
          "publishCmd": "docker push ghcr.io/${GITHUB_REPOSITORY}:${nextRelease.version} && docker push ghcr.io/${GITHUB_REPOSITORY}:latest"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
